# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Bot → Backend: секрет для внутренних вызовов (заявки в друзья, подтверждение прикола, быстрый прикол)
# Если не задан, бот использует TELEGRAM_BOT_TOKEN
BOT_SECRET=optional-same-as-token-or-custom-secret

# Bot: URL бэкенда для вызова внутренних API (по умолчанию http://localhost:3000)
BACKEND_URL=http://localhost:3000

# Mini App URL (HTTPS; for dev use ngrok or similar)
MINI_APP_URL=https://your-app.example.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/prankster

# Backend
HOST=0.0.0.0
PORT=3000

# Webapp: URL бэкенда (Vite читает из этого файла через envDir)
# Локально: http://localhost:3000
# Mini App из Telegram: URL туннеля на бэкенд (порт 3000), без слэша в конце
VITE_API_URL=http://localhost:3000
