{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc && cp -r src/__generated__ dist/",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prankster/shared": "file:../shared",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.1.0",
    "sharp": "^0.33.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.0"
  }
}
